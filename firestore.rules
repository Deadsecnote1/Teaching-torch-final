rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin via a secure allowlist document
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admins/allowedList) &&
             request.auth.uid in get(/databases/$(database)/documents/admins/allowedList).data.uids;
    }

    // === PUBLIC COLLECTIONS ===
    
    // Resources: Anyone can read, but only verified admins can modify
    match /resources/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // === METADATA COLLECTIONS ===
    
    // Grades: Publicly readable for navigation, admin only for edits
    match /grades/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subjects: Publicly readable for navigation, admin only for edits
    match /subjects/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings: Publicly readable for navigation, admin only for edits
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === AL COLLECTIONS ===

    match /al_streams/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /al_subjects/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /al_resource_types/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /al_sub_categories/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /al_resources/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins list: Only existing admins can see/edit the allowlist
    match /admins/{document=**} {
      allow read, write: if isAdmin();
    }

    // === USER DATA ===
    
    // User profiles: Users can only see and edit their own private data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // === DEFAULT DENY ===
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
