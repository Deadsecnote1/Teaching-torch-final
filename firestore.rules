rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Anyone can READ resources, grades, subjects, and settings (Students)
    match /resources/{document=**} {
      allow read: if true;
    }
    match /grades/{document=**} {
      allow read: if true;
    }
    match /subjects/{document=**} {
      allow read: if true;
    }
    match /settings/{document=**} {
      allow read: if true;
    }
    match /resource_types/{document=**} {
      allow read: if true;
    }
    
    // A/L Collections
    match /al_streams/{document=**} {
      allow read: if true;
    }
    match /al_subjects/{document=**} {
      allow read: if true;
    }
    match /al_resource_types/{document=**} {
      allow read: if true;
    }
    match /al_sub_categories/{document=**} {
      allow read: if true;
    }
    match /al_resources/{document=**} {
      allow read: if true;
    }

    // 2. Only LOGGED IN ADMINS can WRITE (Create, Update, Delete)
    match /{document=**} {
      allow write: if request.auth != null;
    }
  }
}
